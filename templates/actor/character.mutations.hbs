<section class="actor tab mutations {{tab.cssClass}}" data-group="primary" data-tab="mutations">
  <section class="brp-powers brp-powers-mutations">
    <section class="brp-power-section">
      <div class="brp-power-section-header">
        <div class="brp-power-section-title">{{powersView.mutations.label}}</div>
        <a class="brp-icon-button largeIcon" data-action="{{powersView.mutations.createAction.action}}" data-document-class="{{powersView.mutations.createAction.documentClass}}" data-type="{{powersView.mutations.createAction.type}}" data-tooltip="{{localize powersView.mutations.addTooltip type=powersView.mutations.label}}">
          <i class="item-control fas fa-plus"></i>
        </a>
      </div>

      <ol class="brp-power-list brp-power-list-mutations">
        {{#each powersView.mutations.rows as |mutation id|}}
          <li class="item brp-power-row brp-power-row-mutation {{#if mutation.hasEffects}}has-effects{{/if}}" data-item-id="{{mutation.id}}" data-document-class="{{mutation.documentType}}" data-drag="true">
            <div class="brp-power-main">
              <div class="brp-power-name rollable truncate {{#if mutation.flags.hasEffects}}italics bold{{/if}}" data-action="viewDoc" data-tooltip="{{localize 'BRP.viewSpell' type=../powersView.mutations.label }}">
                {{mutation.displayTitle}}
              </div>
              {{#if mutation.shortDescription}}<div class="brp-power-subtitle truncate">{{mutation.shortDescription}}</div>{{/if}}
            </div>

            <div class="brp-power-actions"></div>

            <div class="brp-power-cells">
              {{#each mutation.summaryCells as |cell key|}}
                <div class="brp-power-cell {{#if cell.rollable}}rollable{{/if}}" {{#if cell.action}}data-action="{{cell.action}}"{{/if}} {{#if cell.tooltipKey}}data-tooltip="{{localize cell.tooltipKey}}"{{/if}}>
                  <span>{{#if cell.labelKey}}{{localize cell.labelKey}}{{else}}{{cell.label}}{{/if}}</span>
                  <strong>{{#if cell.valueKey}}{{localize cell.valueKey}}{{else}}{{cell.value}}{{/if}}</strong>
                </div>
              {{/each}}
            </div>
          </li>
        {{/each}}
      </ol>
    </section>
  </section>
</section>
