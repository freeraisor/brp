                  <small>{{localize stat.label}}</small>
                  <strong>{{stat.value}}</strong>
                </span>
              {{/each}}
            </span>
            <span class="brp-items-refresh-actions">
              <a class="brp-items-refresh-action brp-items-refresh-favorite {{#if row.flags.favorite}}is-active{{/if}}" data-action="inventoryFavoriteToggle" data-tooltip="{{#if row.flags.favorite}}{{localize 'BRP.skillContextUnfavorite'}}{{else}}{{localize 'BRP.skillContextFavorite'}}{{/if}}"><i class="{{#if row.flags.favorite}}fas{{else}}far{{/if}} fa-star"></i></a>
              <a class="brp-items-refresh-action {{#if row.flags.carried}}is-active is-carry{{/if}}" data-action="inventoryStatusToggle" data-tooltip="{{row.equippedName}}"><i class="fas fa-hand-holding"></i></a>
              {{#if row.consumable}}
                <a class="brp-items-refresh-action {{#unless row.consumable.canUse}}is-disabled{{/unless}}" data-action="inventoryUseConsumable" data-tooltip="{{localize 'BRP.inventoryUse'}}"><i class="fas fa-flask"></i></a>
                {{#if row.consumable.canSplit}}<a class="brp-items-refresh-action" data-action="inventorySplitStack" data-tooltip="{{localize 'BRP.inventorySplitStack'}}"><i class="fas fa-code-branch"></i></a>{{/if}}
              {{/if}}
              <a class="brp-items-refresh-action" data-action="viewDoc" data-tooltip="{{localize 'BRP.viewDoc' type=row.typeLabel}}"><i class="fas fa-eye"></i></a>
              <a class="brp-items-refresh-action" data-action="inventoryDuplicate" data-tooltip="{{localize 'BRP.duplicate'}}"><i class="fas fa-copy"></i></a>
              <a class="brp-items-refresh-action" data-action="inventoryDelete" data-tooltip="{{localize 'BRP.deleteItem'}}"><i class="fas fa-trash"></i></a>
            </span>
            <button type="button" class="brp-items-refresh-chevron" data-action="inventoryDetailsToggle" aria-label="{{localize 'BRP.details'}}">
              <i class="fas fa-chevron-down"></i>
            </button>
            <div class="brp-items-refresh-details" {{#unless row.flags.detailsOpen}}hidden{{/unless}}>
              {{#if row.consumable}}<span><small>{{localize 'BRP.useEffect'}}</small> {{row.consumable.useEffectLabel}}</span>{{/if}}
              {{#each row.bonusRows as |bonus|}}
                <span class="brp-items-refresh-bonus-detail brp-items-refresh-bonus-{{bonus.mode}} {{#if bonus.inactive}}is-inactive{{/if}}" data-tooltip="{{bonus.tooltip}}"><small>{{localize 'BRP.bonus'}}</small> {{bonus.detailLabel}}</span>
              {{/each}}
              {{#if row.loot}}<span><small>{{localize 'BRP.value'}}</small> {{row.loot.value}}</span>{{/if}}
            </div>

            {{#if row.container}}
              <div class="brp-items-refresh-container-body" {{#unless row.flags.detailsOpen}}hidden{{/unless}}>
                <div class="brp-items-refresh-container-info">
                  <span>{{localize 'BRP.enc'}} <strong>{{row.container.effectiveEnc}}</strong></span>
                  <span class="{{#if row.container.overCapacity}}is-over-capacity{{/if}}">{{localize 'BRP.capacityEnc'}} <strong>{{row.container.capacityLabel}}</strong></span>
                  <span>{{localize 'BRP.encReductionPct'}} <strong>{{row.container.encReductionPct}}%</strong></span>
                </div>
                <ol class="brp-items-refresh-nested-list">
                  {{#each row.children as |child|}}
                    <li class="item brp-items-refresh-row brp-items-refresh-row-nested brp-items-refresh-row-depth-{{child.depth}} brp-items-refresh-row-{{child.mockType}} {{#unless child.flags.carried}}is-not-carried{{/unless}} {{#if child.flags.favorite}}is-favorite{{/if}} {{#if child.flags.overCapacity}}is-over-capacity{{/if}} {{#if child.flags.detailsOpen}}is-details-open{{/if}} {{#if child.container}}is-container-row{{/if}}" data-item-id="{{child.id}}" data-document-class="{{child.documentType}}" data-search-text="{{child.searchText}}" {{#if child.container}}data-inventory-container-row-drop="{{child.id}}"{{/if}}>
                      <span class="brp-items-refresh-handle" draggable="true" data-inventory-row-drag="{{child.id}}">::</span>
                      <span class="brp-items-refresh-item-icon">
                        {{#if child.icon.path}}
                          <svg viewBox="{{child.icon.viewBox}}" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="{{child.icon.path}}"></path>
                          </svg>
                        {{else}}
                          <i class="{{child.icon}}"></i>
                        {{/if}}
                      </span>
                      <span class="brp-items-refresh-main" data-action="viewDoc" data-tooltip="{{localize 'BRP.viewDoc' type=child.typeLabel}}">
                        <strong>{{child.name}}</strong>
                        <em>{{child.typeLabel}}{{#if child.subtitle}} - {{child.subtitle}}{{/if}}</em>
                        {{#if child.hasBonuses}}
                          <span class="brp-items-refresh-bonus-strip">
                            {{#each child.bonusPreviewRows as |bonus|}}
                              <span class="brp-items-refresh-bonus brp-items-refresh-bonus-{{bonus.mode}} {{#if bonus.inactive}}is-inactive{{/if}}" data-tooltip="{{bonus.tooltip}}">{{bonus.compactLabel}}</span>
                            {{/each}}
                            {{#if child.bonusOverflow}}<span class="brp-items-refresh-bonus brp-items-refresh-bonus-more">+{{child.bonusOverflow}}</span>{{/if}}
                          </span>
                        {{/if}}
                      </span>
                      <span class="brp-items-refresh-stats">
                        {{#each child.stats as |stat|}}
                          <span class="brp-items-refresh-stat brp-items-refresh-stat-{{stat.id}}">
                            <small>{{localize stat.label}}</small>
                            <strong>{{stat.value}}</strong>
                          </span>
                        {{/each}}
                      </span>
                      <span class="brp-items-refresh-actions">
                        <a class="brp-items-refresh-action brp-items-refresh-favorite {{#if child.flags.favorite}}is-active{{/if}}" data-action="inventoryFavoriteToggle" data-tooltip="{{#if child.flags.favorite}}{{localize 'BRP.skillContextUnfavorite'}}{{else}}{{localize 'BRP.skillContextFavorite'}}{{/if}}"><i class="{{#if child.flags.favorite}}fas{{else}}far{{/if}} fa-star"></i></a>
                        <a class="brp-items-refresh-action {{#if child.flags.carried}}is-active is-carry{{/if}}" data-action="inventoryStatusToggle" data-tooltip="{{child.equippedName}}"><i class="fas fa-hand-holding"></i></a>
                        {{#if child.consumable}}
                          <a class="brp-items-refresh-action {{#unless child.consumable.canUse}}is-disabled{{/unless}}" data-action="inventoryUseConsumable" data-tooltip="{{localize 'BRP.inventoryUse'}}"><i class="fas fa-flask"></i></a>
                          {{#if child.consumable.canSplit}}<a class="brp-items-refresh-action" data-action="inventorySplitStack" data-tooltip="{{localize 'BRP.inventorySplitStack'}}"><i class="fas fa-code-branch"></i></a>{{/if}}
                        {{/if}}
                        <a class="brp-items-refresh-action" data-action="viewDoc" data-tooltip="{{localize 'BRP.viewDoc' type=child.typeLabel}}"><i class="fas fa-eye"></i></a>
                        <a class="brp-items-refresh-action" data-action="inventoryDuplicate" data-tooltip="{{localize 'BRP.duplicate'}}"><i class="fas fa-copy"></i></a>
                        <a class="brp-items-refresh-action" data-action="inventoryDelete" data-tooltip="{{localize 'BRP.deleteItem'}}"><i class="fas fa-trash"></i></a>
                      </span>
                      <button type="button" class="brp-items-refresh-chevron" data-action="inventoryDetailsToggle" aria-label="{{localize 'BRP.details'}}">
                        <i class="fas fa-chevron-down"></i>
                      </button>
                      <div class="brp-items-refresh-details" {{#unless child.flags.detailsOpen}}hidden{{/unless}}>
                        {{#each child.details as |detail|}}
                          <span><small>{{localize detail.label}}</small> {{detail.value}}</span>
                        {{/each}}
                        {{#if child.consumable}}<span><small>{{localize 'BRP.useEffect'}}</small> {{child.consumable.useEffectLabel}}</span>{{/if}}
                        {{#each child.bonusRows as |bonus|}}
                          <span class="brp-items-refresh-bonus-detail brp-items-refresh-bonus-{{bonus.mode}} {{#if bonus.inactive}}is-inactive{{/if}}" data-tooltip="{{bonus.tooltip}}"><small>{{localize 'BRP.bonus'}}</small> {{bonus.detailLabel}}</span>
                        {{/each}}
                      </div>
                      {{#if child.container}}
                        <div class="brp-items-refresh-container-body" {{#unless child.flags.detailsOpen}}hidden{{/unless}}>
                          <div class="brp-items-refresh-container-info">
                            <span>{{localize 'BRP.enc'}} <strong>{{child.container.effectiveEnc}}</strong></span>
                            <span class="{{#if child.container.overCapacity}}is-over-capacity{{/if}}">{{localize 'BRP.capacityEnc'}} <strong>{{child.container.capacityLabel}}</strong></span>
                            <span>{{localize 'BRP.encReductionPct'}} <strong>{{child.container.encReductionPct}}%</strong></span>
                          </div>
                          <div class="brp-items-refresh-drop-zone" data-inventory-container-drop="{{child.id}}">{{localize 'BRP.inventoryDropContainer'}}</div>
                        </div>
                      {{/if}}
                    </li>
                  {{else}}
                    <li class="brp-items-refresh-container-empty">{{localize 'BRP.none'}}</li>
                  {{/each}}
                </ol>
                <div class="brp-items-refresh-drop-zone" data-inventory-container-drop="{{row.id}}">{{localize 'BRP.inventoryDropContainer'}}</div>
              </div>
            {{/if}}
          </li>
        {{else}}
          <li class="brp-items-refresh-empty">{{localize 'BRP.none'}}</li>
        {{/each}}
      </ol>
      <div class="brp-items-refresh-drop-zone" data-inventory-top-drop="other">{{localize 'BRP.inventoryDropTopLevel'}}</div>
    </section>
  </section>
</section>
