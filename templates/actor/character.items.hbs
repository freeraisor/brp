<section class="actor tab items {{tab.cssClass}}" data-group="primary" data-tab="items">
  <section class="brp-items-refresh">
    <header class="brp-items-refresh-titlebar">
      <div class="brp-items-refresh-title">
        <i class="fas fa-cube"></i>
        <span>{{localize 'BRP.items'}}</span>
      </div>
      <div class="brp-items-refresh-lock">
        {{#if system.lock}}
          <i class="fas fa-lock"></i>
          <span>{{localize 'BRP.locked'}}</span>
        {{else}}
          <i class="fas fa-lock-open"></i>
          <span>{{localize 'BRP.unlocked'}}</span>
        {{/if}}
      </div>
    </header>

    <section class="brp-items-refresh-header">
      <div class="brp-items-refresh-enc">
        <div class="brp-items-refresh-enc-head">
          <span>{{localize 'BRP.enc'}}</span>
          <strong>{{inventoryView.encumbrance.current}}</strong>
          <em>{{localize 'BRP.actualENC'}} {{inventoryView.encumbrance.preview}}</em>
        </div>
        <div class="brp-items-refresh-enc-bar">
          <span style="width: 50%"></span>
          <i style="left: 50%" data-label="Medium"></i>
          <i style="left: 75%" data-label="Heavy"></i>
        </div>
        <div class="brp-items-refresh-enc-zones">
          <span>Light</span>
          <span>Medium</span>
          <span>Heavy</span>
        </div>
      </div>

      <div class="brp-items-refresh-currencies">
        <span class="brp-items-refresh-currency-label">{{localize 'BRP.price'}}</span>
        {{#each inventoryView.currencies as |currency|}}
          <button type="button" class="brp-items-refresh-currency brp-items-refresh-currency-{{currency.icon}}" data-action="inventoryCurrencyEdit" data-currency-id="{{currency.id}}" data-tooltip="{{localize 'BRP.inventoryCurrencyEdit'}}">
            {{#if (eq currency.icon 'bill')}}<i class="fas fa-money-bill"></i>{{/if}}
            {{#if (eq currency.icon 'card')}}<i class="fas fa-credit-card"></i>{{/if}}
            {{#if (eq currency.icon 'coin')}}<i class="fas fa-coins"></i>{{/if}}
            {{#if (eq currency.icon 'crypto')}}<i class="fas fa-bitcoin-sign"></i>{{/if}}
            {{#if (eq currency.icon 'gem')}}<i class="fas fa-gem"></i>{{/if}}
            {{#if (eq currency.icon 'token')}}<i class="fas fa-circle-dot"></i>{{/if}}
            <span>{{currency.name}}</span>
            <strong>{{currency.amount}}</strong>
          </button>
        {{/each}}
        <button type="button" class="brp-items-refresh-currency-add" data-action="inventoryCurrencyAdd" data-tooltip="{{localize 'BRP.inventoryCurrencyAdd'}}">
          <i class="fas fa-plus"></i>
        </button>
      </div>
    </section>

    <section class="brp-items-refresh-toolbar">
      <label class="brp-items-refresh-search">
        <i class="fas fa-search"></i>
        <input type="search" class="brp-items-refresh-search-input" placeholder="{{localize 'BRP.search'}}" autocomplete="off" />
      </label>
      <button type="button" class="brp-items-refresh-tool {{#if inventoryView.filters.activeCount}}is-active{{/if}}" data-action="inventoryFilterToggle">
        <i class="fas fa-filter"></i>
        <span>{{localize 'BRP.filters'}}</span>
        {{#if inventoryView.filters.activeCount}}<b>{{inventoryView.filters.activeCount}}</b>{{/if}}
      </button>
      <a class="brp-items-refresh-tool"
        data-action="{{inventoryView.sections.other.createAction.action}}"
        data-document-class="{{inventoryView.sections.other.createAction.documentClass}}"
        data-type="{{inventoryView.sections.other.createAction.type}}"
        data-tooltip="{{localize 'BRP.addGear'}}">
        <i class="fas fa-plus"></i>
      </a>
    </section>

    <section class="brp-items-refresh-filter-panel" hidden>
      <div>
        <span>{{localize 'BRP.inventoryFilterByType'}}</span>
        {{#each inventoryView.filters.typeOptions as |filter|}}
          <label>
            <input type="checkbox" class="brp-items-refresh-filter-input" data-inventory-filter-type="{{filter.id}}" {{#if filter.checked}}checked{{/if}} />
            {{localize filter.label}}
          </label>
        {{/each}}
      </div>
      <div>
        <span>{{localize 'BRP.inventoryFilterByState'}}</span>
        <label><input type="checkbox" class="brp-items-refresh-filter-input" data-inventory-filter="equipped" {{#if inventoryView.filters.equipped}}checked{{/if}} /> {{localize 'BRP.equipped'}}</label>
        <label><input type="checkbox" class="brp-items-refresh-filter-input" data-inventory-filter="carried" {{#if inventoryView.filters.carried}}checked{{/if}} /> {{localize 'BRP.carried'}}</label>
        <label><input type="checkbox" class="brp-items-refresh-filter-input" data-inventory-filter="favorite" {{#if inventoryView.filters.favorite}}checked{{/if}} /> {{localize 'BRP.favorites'}}</label>
        <label><input type="checkbox" class="brp-items-refresh-filter-input" data-inventory-filter="hideEmpty" {{#if inventoryView.filters.hideEmpty}}checked{{/if}} /> {{localize 'BRP.inventoryHideEmpty'}}</label>
      </div>
    </section>

    <section class="brp-items-refresh-section {{#if inventoryView.sections.weapons.collapsed}}is-collapsed{{/if}}" data-inventory-section="weapons">
      <header class="brp-items-refresh-section-header">
        <button type="button" class="brp-items-refresh-section-toggle" data-action="inventorySectionToggle" data-section-id="weapons" data-tooltip="{{#if inventoryView.sections.weapons.collapsed}}{{localize 'BRP.expand'}}{{else}}{{localize 'BRP.collapse'}}{{/if}}">
          <i class="fas fa-chevron-down"></i>
        </button>
        <h3>{{localize inventoryView.sections.weapons.label}}</h3>
        <span>{{inventoryView.sections.weapons.rows.length}}</span>
        <button type="button" class="brp-items-refresh-sort" data-action="inventorySortToggle" data-section-id="weapons" data-sort-mode="{{inventoryView.sections.weapons.sort.mode}}">
          <i class="{{inventoryView.sections.weapons.sort.icon}}"></i>
          <span>{{localize inventoryView.sections.weapons.sort.label}}</span>
        </button>
        <b></b>
        <a class="brp-items-refresh-icon-action"
          data-action="{{inventoryView.sections.weapons.createAction.action}}"
          data-document-class="{{inventoryView.sections.weapons.createAction.documentClass}}"
          data-type="{{inventoryView.sections.weapons.createAction.type}}"
          data-tooltip="{{localize 'BRP.addWeapon'}}">
          <i class="fas fa-plus"></i>
        </a>
      </header>
      <div class="brp-items-refresh-sort-menu" hidden>
        {{#each inventoryView.sections.weapons.sort.options as |option|}}
          <button type="button" class="brp-items-refresh-sort-option {{#if option.active}}is-active{{/if}}" data-action="inventorySortSelect" data-section-id="weapons" data-sort-mode="{{option.mode}}">
            <i class="{{option.icon}}"></i>
            <span>{{localize option.label}}</span>
          </button>
        {{/each}}
      </div>
      <ol class="brp-items-refresh-list">
        {{#each inventoryView.sections.weapons.rows as |row|}}
          <li class="item brp-items-refresh-row brp-items-refresh-row-{{row.mockType}} {{#if row.flags.equipped}}is-equipped{{/if}} {{#unless row.flags.carried}}is-not-carried{{/unless}} {{#if row.flags.empty}}is-empty{{/if}} {{#if row.flags.favorite}}is-favorite{{/if}} {{#if row.flags.overCapacity}}is-over-capacity{{/if}} {{#if row.flags.detailsOpen}}is-details-open{{/if}}" data-item-id="{{row.id}}" data-document-class="{{row.documentType}}" data-search-text="{{row.searchText}}">
            <span class="brp-items-refresh-handle" draggable="true" data-inventory-row-drag="{{row.id}}">::</span>
            <span class="brp-items-refresh-item-icon">
              {{#if row.icon.path}}
                <svg viewBox="{{row.icon.viewBox}}" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="{{row.icon.path}}"></path>
                </svg>
              {{else}}
                <i class="{{row.icon}}"></i>
              {{/if}}
            </span>
            <span class="brp-items-refresh-main" data-action="viewDoc" data-tooltip="{{localize 'BRP.viewDoc' type=row.typeLabel}}">
              <strong>{{row.name}}</strong>
              <em>{{row.typeLabel}}{{#if row.subtitle}} - {{row.subtitle}}{{/if}}</em>
              {{#if row.hasBonuses}}
                <span class="brp-items-refresh-bonus-strip">
                  {{#each row.bonusPreviewRows as |bonus|}}
                    <span class="brp-items-refresh-bonus brp-items-refresh-bonus-{{bonus.mode}} {{#if bonus.inactive}}is-inactive{{/if}}" data-tooltip="{{bonus.tooltip}}">{{bonus.compactLabel}}</span>
                  {{/each}}
                  {{#if row.bonusOverflow}}<span class="brp-items-refresh-bonus brp-items-refresh-bonus-more">+{{row.bonusOverflow}}</span>{{/if}}
                </span>
              {{/if}}
            </span>
            <span class="brp-items-refresh-stats">
              {{#each row.stats as |stat|}}
                <span class="brp-items-refresh-stat brp-items-refresh-stat-{{stat.id}}" data-tooltip="{{stat.tooltip}}">
                  <small>{{localize stat.label}}</small>
                  <strong>{{stat.value}}</strong>
                </span>
              {{/each}}
            </span>
            <span class="brp-items-refresh-actions">
              <a class="brp-items-refresh-action brp-items-refresh-favorite {{#if row.flags.favorite}}is-active{{/if}}" data-action="inventoryFavoriteToggle" data-tooltip="{{#if row.flags.favorite}}{{localize 'BRP.skillContextUnfavorite'}}{{else}}{{localize 'BRP.skillContextFavorite'}}{{/if}}"><i class="{{#if row.flags.favorite}}fas{{else}}far{{/if}} fa-star"></i></a>
              <a class="brp-items-refresh-action {{#if row.flags.carried}}is-active is-carry{{/if}}" data-action="inventoryStatusToggle" data-tooltip="{{row.equippedName}}"><i class="fas fa-hand-holding"></i></a>
              <a class="brp-items-refresh-action {{#if row.flags.equipped}}is-active{{/if}}" data-action="inventoryStatusToggle" data-tooltip="{{row.equippedName}}"><i class="fas fa-bolt"></i></a>
              <a class="brp-items-refresh-action" data-action="viewDoc" data-tooltip="{{localize 'BRP.viewDoc' type=row.typeLabel}}"><i class="fas fa-eye"></i></a>
              <a class="brp-items-refresh-action" data-action="inventoryDuplicate" data-tooltip="{{localize 'BRP.duplicate'}}"><i class="fas fa-copy"></i></a>
              <a class="brp-items-refresh-action" data-action="inventoryDelete" data-tooltip="{{localize 'BRP.deleteItem'}}"><i class="fas fa-trash"></i></a>
            </span>
            <button type="button" class="brp-items-refresh-chevron" data-action="inventoryDetailsToggle" aria-label="{{localize 'BRP.details'}}">
              <i class="fas fa-chevron-down"></i>
            </button>
            <div class="brp-items-refresh-details" {{#unless row.flags.detailsOpen}}hidden{{/unless}}>
              {{#each row.details as |detail|}}
                <span><small>{{localize detail.label}}</small> {{detail.value}}</span>
              {{/each}}
              {{#each row.bonusRows as |bonus|}}
                <span class="brp-items-refresh-bonus-detail brp-items-refresh-bonus-{{bonus.mode}} {{#if bonus.inactive}}is-inactive{{/if}}" data-tooltip="{{bonus.tooltip}}"><small>{{localize 'BRP.bonus'}}</small> {{bonus.detailLabel}}</span>
              {{/each}}
            </div>
          </li>
        {{else}}
          <li class="brp-items-refresh-empty">{{localize 'BRP.none'}}</li>
        {{/each}}
      </ol>
      <div class="brp-items-refresh-drop-zone" data-inventory-top-drop="weapons">{{localize 'BRP.inventoryDropTopLevel'}}</div>
    </section>

    <section class="brp-items-refresh-section {{#if inventoryView.sections.armour.collapsed}}is-collapsed{{/if}}" data-inventory-section="armour">
      <header class="brp-items-refresh-section-header">
