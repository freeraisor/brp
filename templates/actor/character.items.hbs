              <a class="brp-items-refresh-action {{#if row.flags.carried}}is-active is-carry{{/if}}" data-action="inventoryStatusToggle" data-tooltip="{{row.equippedName}}"><i class="fas fa-hand-holding"></i></a>
              <a class="brp-items-refresh-action {{#if row.flags.equipped}}is-active{{/if}}" data-action="inventoryArmourWornToggle" data-tooltip="{{row.equippedName}}"><i class="fas fa-shirt"></i></a>
              <a class="brp-items-refresh-action" data-action="viewDoc" data-tooltip="{{localize 'BRP.viewDoc' type=row.typeLabel}}"><i class="fas fa-eye"></i></a>
