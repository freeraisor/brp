<section class="actor tab combat {{tab.cssClass}}" data-group="primary" data-tab="combat">
  <section class="brp-combat-refresh">
    <header class="brp-combat-refresh-header">
      <div class="brp-combat-refresh-title">{{localize 'BRP.combat'}}</div>
      <div class="brp-combat-refresh-lock">
        <i class="fas {{#if system.lock}}fa-lock{{else}}fa-lock-open{{/if}}"></i>
      </div>
    </header>

    <section class="brp-combat-refresh-section">
      <header class="brp-combat-refresh-section-header">
        <div class="brp-combat-refresh-section-title">{{localize 'BRP.defense'}}</div>
        <span class="brp-combat-refresh-section-line"></span>
      </header>

      <ol class="brp-combat-defense-grid">
        {{#each combatView.defense as |defense key|}}
          <li class="brp-combat-defense-card {{#if defense.available}}rollable{{else}}is-disabled{{/if}}" data-defense-id="{{defense.id}}" data-skill-id="{{defense.skillId}}" data-item-id="{{defense.defaultItemId}}" {{#if defense.available}}data-action="{{defense.action}}"{{/if}}>
            <div class="brp-combat-defense-icon">
              <i class="{{defense.icon}}"></i>
            </div>
            <div class="brp-combat-defense-main">
              <div class="brp-combat-defense-label truncate">{{defense.label}}</div>
              <div class="brp-combat-defense-subtitle truncate">{{defense.subtitle}}</div>
            </div>
            <div class="brp-combat-defense-percent">
              {{#if defense.available}}{{defense.percent}}%{{else}}&mdash;{{/if}}
            </div>
          </li>
        {{/each}}
      </ol>
    </section>

    <section class="brp-combat-refresh-section brp-combat-refresh-weapons">
      <header class="brp-combat-refresh-section-header">
        <div class="brp-combat-refresh-section-title">{{localize 'BRP.weapons'}}</div>
        <span class="brp-combat-refresh-section-line"></span>
        <div class="brp-combat-refresh-actions">
          <a class="brp-icon-button brp-combat-refresh-sort-button" data-action="combatSortToggle" data-sort-mode="{{combatView.sort.mode}}" data-tooltip="{{localize combatView.sort.label}}">
            <i class="{{combatView.sort.icon}}"></i>
          </a>
          <a class="brp-icon-button" data-action="createDoc" data-document-class="Item" data-type="weapon" data-tooltip="{{localize 'BRP.addWeapon'}}">
            <i class="fas fa-plus"></i>
          </a>
        </div>
      </header>

      <div class="brp-combat-refresh-sort-menu" hidden>
        {{#each combatView.sort.options as |option key|}}
          <button class="brp-combat-refresh-sort-option {{#if option.active}}is-active{{/if}}" type="button" data-action="combatSortSelect" data-sort-mode="{{option.mode}}">
            <i class="{{option.icon}}"></i>
            <span>{{localize option.label}}</span>
          </button>
        {{/each}}
      </div>

      <ol class="brp-combat-refresh-weapon-list">
        {{#each combatView.weapons as |weapon key|}}
          <li class="item brp-combat-refresh-weapon {{weapon.rowClass}} {{#if weapon.hasEffects}}has-effects{{/if}} {{#if weapon.detailsOpen}}is-details-open{{/if}}" data-item-id="{{weapon.id}}" data-skill-id="{{weapon.sourceID}}" data-document-class="Item" data-drag="true" data-search-text="{{weapon.searchText}}">
            <div class="brp-combat-refresh-weapon-row">
              <span class="brp-combat-refresh-drag-handle" aria-hidden="true" draggable="true" data-combat-weapon-drag="{{weapon.id}}">&#8942;&#8942;</span>

              <div class="brp-combat-refresh-weapon-icon {{weapon.iconClass}}">
                <i class="{{weapon.icon}}"></i>
              </div>

              <div class="brp-combat-refresh-weapon-main">
                <div class="brp-combat-refresh-weapon-name rollable truncate" data-action="viewDoc" data-tooltip="{{localize 'BRP.viewDoc' type=(localize 'TYPES.Item.weapon')}}">
                  {{weapon.name}}
                </div>
                <div class="brp-combat-refresh-weapon-meta">
                  <span class="is-attacks" data-tooltip="{{localize 'BRP.rof'}}: {{weapon.rof}}">ATK &times;{{weapon.attacks}}</span>
                  <span>{{#if (eq weapon.type 'artillery')}}CREW {{weapon.crew}}{{else}}{{weapon.hands}}{{/if}}</span>
                  <span data-tooltip="{{localize 'BRP.quantity'}}: {{weapon.quantity}}">ENC {{weapon.encumbrance}}</span>
                </div>
              </div>

              <a class="brp-combat-refresh-percent rollable" data-action="combatWeaponRoll" data-tooltip="{{weapon.skillName}}">
                {{weapon.skillScore}}%
              </a>

              <a class="brp-combat-refresh-damage {{#if weapon.damage.rollable}}rollable{{else}}is-disabled{{/if}}" {{#if weapon.damage.rollable}}data-action="damageRoll"{{/if}} data-tooltip="{{weapon.damage.tooltip}}">
                <span class="brp-combat-refresh-damage-value">{{weapon.damage.label}}</span>
                {{#if weapon.damage.showBonus}}<span class="brp-combat-refresh-damage-bonus">+{{weapon.damage.bonusLabel}}</span>{{/if}}
              </a>

              <div class="brp-combat-refresh-range" data-tooltip="{{weapon.range.tooltip}}">
                {{weapon.range.label}}
              </div>

              <div class="brp-combat-refresh-ammo brp-combat-refresh-ammo-{{weapon.ammo.mode}} {{#if (eq weapon.ammo.mode 'none')}}is-empty{{/if}}">
                {{#if (eq weapon.ammo.mode 'count')}}
                  <div class="brp-combat-refresh-count-pill {{#if weapon.ammo.critical}}is-critical{{/if}}">
                    <span class="brp-combat-refresh-count-label">&times;</span>
                    <span class="brp-combat-refresh-count-value">{{weapon.ammo.quantity}}</span>
                  </div>
                {{/if}}
                {{#if (eq weapon.ammo.mode 'single')}}
                  <div class="brp-combat-refresh-ammo-mag {{#if weapon.ammo.low}}is-low{{/if}} {{#if weapon.ammo.critical}}is-critical{{/if}}">
                    <span class="brp-combat-refresh-ammo-label">{{weapon.ammo.typeLabel}}</span>
                    <span class="brp-combat-refresh-ammo-current">{{weapon.ammo.current}}</span>
                  </div>
                {{/if}}
                {{#if (eq weapon.ammo.mode 'magazine')}}
                  <div class="brp-combat-refresh-ammo-mag {{#if weapon.ammo.low}}is-low{{/if}} {{#if weapon.ammo.critical}}is-critical{{/if}}">
                    <span class="brp-combat-refresh-ammo-label">AMMO</span>
                    <span class="brp-combat-refresh-ammo-current">{{weapon.ammo.current}}</span>
                    <span class="brp-combat-refresh-ammo-max">/ {{weapon.ammo.max}}</span>
                  </div>
                  <div class="brp-combat-refresh-mag-row">
                    <div class="brp-combat-refresh-mag-count">
                      <span class="brp-combat-refresh-mag-label">MAG</span>
                      <span class="brp-combat-refresh-mag-count-value">{{weapon.ammo.magazineCount}}</span>
                    </div>
                    <button class="brp-combat-refresh-reload" type="button" data-action="combatWeaponReload" data-tooltip="{{localize 'BRP.reload'}}">
                      <i class="fas fa-rotate-right"></i>
                    </button>
                  </div>
                {{/if}}
              </div>

              <button class="brp-combat-refresh-details-toggle {{#if weapon.detailsOpen}}is-active{{/if}}" type="button" data-action="combatDetailsToggle" aria-label="{{localize 'BRP.details'}}">
                <i class="fas fa-chevron-down"></i>
              </button>
            </div>

            <div class="brp-combat-refresh-weapon-details" {{#unless weapon.detailsOpen}}hidden{{/unless}}>
              <div class="brp-combat-refresh-detail-grid">
                {{#each weapon.details as |detail detailKey|}}
                  <div class="brp-combat-refresh-detail">
                    <span class="brp-combat-refresh-detail-label">{{localize detail.label}}</span>
                    <span class="brp-combat-refresh-detail-value {{detail.valueClass}}">{{detail.value}}</span>
                  </div>
                {{/each}}
                {{#if weapon.notes}}
                  <div class="brp-combat-refresh-notes">{{weapon.notes}}</div>
                {{/if}}
              </div>
            </div>
          </li>
        {{else}}
          <li class="brp-combat-refresh-empty">{{localize 'BRP.combatNoWeapons'}}</li>
        {{/each}}
      </ol>
    </section>
  </section>
</section>
