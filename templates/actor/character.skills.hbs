<section class="actor tab skills {{tab.cssClass}}" data-group="primary" data-tab="skills">
  {{#if system.lock}}
  {{! Normal Skill Layout}}
  <section class="brp-skill-play brp-skill-refresh">
    <header class="brp-skill-refresh-header">
      <div class="brp-skill-refresh-title">{{localize 'BRP.skills'}}</div>
      <div class="brp-skill-refresh-lock"><i class="fas fa-lock"></i></div>
    </header>

    <ol class="brp-characteristic-skill-grid">
      {{#each skillsView.characteristics as |skill key|}}
        <li class="brp-characteristic-skill-card {{#if skill.rollable}}rollable{{else}}is-disabled{{/if}}"
          {{#if skill.rollable}}data-action="{{skill.action}}" data-characteristic="{{skill.characteristicKey}}" data-tooltip="{{localize skill.tooltip}}"{{/if}}>
          <div class="brp-characteristic-skill-main">
            <span class="truncate">{{skill.title}}</span>
            <strong>{{skill.valueDisplay}}</strong>
          </div>
          <div class="brp-characteristic-skill-base">
            <span>{{skill.baseLabel}}</span>
            <strong>{{skill.baseValue}}</strong>
          </div>
        </li>
      {{/each}}
    </ol>

    <div class="brp-skill-refresh-toolbar">
      <label class="brp-skill-search">
        <i class="fas fa-magnifying-glass"></i>
        <input type="search" class="brp-skill-search-input" autocomplete="off" />
      </label>
      <a class="brp-icon-button brp-skill-sort" data-action="skillSortCycle" data-sort-mode="{{skillsView.play.sortMode}}" data-tooltip="{{localize 'BRP.skillOrder'}}">
        <i class="{{skillsView.play.sortIcon}}"></i>
      </a>
      <a class="brp-icon-button" data-action="createDoc" data-document-class="Item" data-type="skill" data-tooltip="{{localize 'BRP.addSkill'}}">
        <i class="fas fa-plus"></i>
      </a>
      <a class="brp-icon-button" data-action="skillCalc" data-tooltip="{{localize 'BRP.calcBase'}}">
        <i class="fas fa-calculator"></i>
      </a>
    </div>

    <section class="brp-skill-groups">
      {{#each skillsView.play.groups as |group key|}}
        <section class="brp-skill-group {{#if group.collapsed}}is-collapsed{{/if}}" data-category-id="{{group.categoryId}}" data-item-id="{{group.id}}">
          <header class="brp-skill-group-header item" data-item-id="{{group.id}}" data-document-class="Item">
            <span class="brp-skill-group-drag" draggable="true" data-category-order-drag="{{group.categoryId}}"><i class="fas fa-grip-vertical"></i></span>
            <a class="brp-skill-group-toggle" data-action="skillCategoryToggle" data-category-id="{{group.categoryId}}" data-tooltip="{{localize 'BRP.collapse'}}">
              <i class="brp-skill-group-chevron fas fa-chevron-down"></i>
            </a>
            <div class="brp-skill-group-title rollable truncate" data-action="viewDoc" data-item-id="{{group.id}}" data-document-class="Item" data-tooltip="{{localize 'BRP.viewDoc' type=(localize 'TYPES.Item.skillcat')}}">
              {{group.title}}
            </div>
            <div class="brp-skill-group-count">{{group.count}}</div>
          </header>

          <ol class="brp-skill-group-list">
            {{#each group.rows as |skill id|}}
              <li class="item brp-skill-row brp-skill-refresh-row {{#if skill.isSpecialism}}brp-skill-row-specialism{{/if}} {{#if skill.isImproving}}is-improving{{/if}} {{#if skill.isFavorite}}is-favorite{{/if}} {{#if skill.descriptionText}}has-description{{/if}} {{#if skill.descriptionOpen}}is-description-open{{/if}}" data-item-id="{{skill.id}}" data-document-class="Item" data-drag="true" data-search-text="{{skill.searchText}}">
                {{#if skill.descriptionText}}
                  <a class="brp-skill-info {{#if skill.descriptionOpen}}is-active{{/if}}" data-action="skillDescriptionToggle" aria-label="{{localize 'BRP.description'}}">
                    <i class="fas fa-circle-info"></i>
                  </a>
                {{else}}
                  <span class="brp-skill-info is-disabled">
                    <i class="fas fa-circle-info"></i>
                  </span>
                {{/if}}
                <div class="brp-skill-name-block">
                  <div class="brp-skill-name-line">
                    <div class="brp-skill-name rollable truncate" data-action="viewDoc" data-tooltip="{{skill.title}}">
                      {{#if skill.isSpecialism}}{{skill.mainName}}{{else}}{{skill.title}}{{/if}}
                    </div>
                    {{#if skill.isSpecialism}}
                      <div class="brp-skill-specialism truncate">{{skill.specialismName}}</div>
                    {{/if}}
                    <a class="brp-skill-favorite {{#if skill.isFavorite}}is-active{{/if}}" data-action="skillFavoriteToggle">
                      <i class="{{#if skill.isFavorite}}fas{{else}}far{{/if}} fa-star"></i>
                    </a>
                  </div>
                </div>
                {{#if skill.canImprove}}
                  <a class="brp-skill-improve {{#if skill.isImproving}}is-active{{/if}}" data-action="skillImproveToggle" data-property="improve" data-tooltip="{{ localize 'BRP.improve' }}">
                    <i class="{{#if skill.isImproving}}fa-regular fa-square-check{{else}}fa-regular fa-square{{/if}}"></i>
                  </a>
                {{else}}
                  <span class="brp-skill-improve"></span>
                {{/if}}
                <div class="brp-skill-total rollable" data-action="skillRoll" data-tooltip="{{localize 'BRP.skillHint'}}">{{skill.grandTotal}}%</div>
                <div class="brp-skill-row-actions">
                  <a class="brp-skill-row-action" data-action="skillDuplicate" data-tooltip="{{localize 'BRP.skillContextDuplicate'}}">
                    <i class="fas fa-copy"></i>
                  </a>
                  <a class="brp-skill-row-action" data-action="skillDelete" data-tooltip="{{localize 'BRP.skillContextDelete'}}">
                    <i class="fas fa-trash"></i>
                  </a>
                </div>
                {{#if skill.descriptionText}}
                  <div class="brp-skill-description" {{#unless skill.descriptionOpen}}hidden{{/unless}}>{{skill.descriptionText}}</div>
                {{/if}}
              </li>
            {{/each}}
          </ol>
        </section>
      {{/each}}
    </section>
  </section>

  {{else}}
  {{! Skill Development Layout}}
  <section class="brp-skill-dev">
    <div class="brp-skill-dev-toolbar">
      <div class="brp-skill-dev-title">{{localize 'BRP.skill'}}</div>
      <a class="brp-icon-button mediumIcon" data-action="skillCalc" data-tooltip="{{localize 'BRP.calcBase'}}">
        <i class="fas fa-calculator"></i>
      </a>
    </div>

    <div class="brp-skill-dev-grid brp-skill-dev-header-row">
      {{#each skillsView.development.columns as |column key|}}
        <div class="brp-skill-dev-heading centre truncate" {{#if column.tooltip}}data-tooltip="{{localize column.tooltip}}"{{/if}}>
          {{localize column.label}}
        </div>
      {{/each}}
    </div>

    <ol class="brp-skill-dev-list">
      {{#each skillsView.development.rows as |skill id|}}
        <li class="item brp-skill-dev-grid brp-skill-dev-row {{#if skill.isImproving}}is-improving{{/if}}" data-item-id="{{skill.id}}" data-document-class='Item'>
          <div class="brp-skill-dev-name-cell">
            <div class="brp-skill-dev-name rollable truncate" data-action="viewDoc" data-tooltip="{{skill.title}}">
              {{skill.title}}
            </div>
            {{#if skill.canImprove}}
              <a class="brp-skill-dev-improve {{#if skill.isImproving}}is-active{{/if}}" data-action="itemToggle" data-property="improve" data-tooltip="{{localize 'BRP.improve'}}">
                <i class="{{#if skill.isImproving}}fa-regular fa-square-check{{else}}fa-regular fa-square{{/if}}"></i>
              </a>
            {{/if}}
          </div>

          {{#each skill.cells as |cell key|}}
            {{#if cell.editable}}
              <input class="brp-skill-dev-input centre inline-edit {{cell.className}}" data-field="{{cell.field}}" name="{{../itemType}}.system.{{cell.field}}" type="number" value="{{cell.value}}" />
            {{else}}
              <div class="brp-skill-dev-cell centre {{cell.className}} {{#if cell.rollable}}rollable{{/if}}" {{#if cell.action}}data-action="{{cell.action}}"{{/if}} {{#if cell.tooltip}}data-tooltip="{{localize cell.tooltip}}"{{/if}}>
                {{cell.value}}
              </div>
            {{/if}}
          {{/each}}
        </li>
      {{/each}}
    </ol>

    <div class="brp-skill-dev-grid brp-skill-dev-total-row">
      <div class="brp-skill-dev-total-label">{{localize 'BRP.total'}}</div>
      <div class="brp-skill-dev-total-cell"></div>
      <div class="brp-skill-dev-total-cell"></div>
      <div class="brp-skill-dev-total-cell" data-tooltip="{{localize 'BRP.pfsp'}}">{{skillsView.development.totals.profession}}</div>
      <div class="brp-skill-dev-total-cell"></div>
      <div class="brp-skill-dev-total-cell" data-tooltip="{{localize 'BRP.psp'}}">{{skillsView.development.totals.personal}}</div>
      <div class="brp-skill-dev-total-cell">{{skillsView.development.totals.xp}}</div>
      <div class="brp-skill-dev-total-cell"></div>
      <div class="brp-skill-dev-total-cell"></div>
      <div class="brp-skill-dev-total-cell"></div>
    </div>
  </section>
  {{/if}}
</section>
