<section class="actor tab psychics {{tab.cssClass}}" data-group="primary" data-tab="psychics">
  {{#if system.lock}}
    {{! Normal Psychics Layout}}
    <section class="brp-powers brp-powers-psychics">
      <section class="brp-power-section">
        <div class="brp-power-section-header">
          <div class="brp-power-section-title">{{powersView.psychics.label}}</div>
          <a class="brp-icon-button largeIcon" data-action="{{powersView.psychics.createAction.action}}" data-document-class="{{powersView.psychics.createAction.documentClass}}" data-type="{{powersView.psychics.createAction.type}}" data-tooltip="{{localize powersView.psychics.addTooltip type=powersView.psychics.label}}">
            <i class="item-control fas fa-plus"></i>
          </a>
        </div>

        <ol class="brp-power-list brp-power-list-psychics">
          {{#each powersView.psychics.rows as |psychic id|}}
            <li class="item brp-power-row brp-power-row-psychic {{#if psychic.hasEffects}}has-effects{{/if}}" data-item-id="{{psychic.id}}" data-document-class="{{psychic.documentType}}" data-drag="true">
              <div class="brp-power-main">
                <div class="brp-power-name rollable truncate {{#if psychic.flags.hasEffects}}italics bold{{/if}}" data-action="viewDoc" data-tooltip="{{localize 'BRP.viewSpell' type=../powersView.psychics.label }}">
                  {{psychic.displayTitle}}
                </div>
                {{#if psychic.shortDescription}}<div class="brp-power-subtitle truncate">{{psychic.shortDescription}}</div>{{/if}}
              </div>

              <div class="brp-power-actions">
                {{#each psychic.actions as |action key|}}
                  <a class="brp-power-action {{#if action.active}}is-active{{/if}}" data-action="{{action.action}}" data-property="{{action.property}}" data-tooltip="{{localize action.tooltipKey}}">
                    <i class="{{#if action.active}}{{action.activeIcon}}{{else}}{{action.inactiveIcon}}{{/if}}"></i>
                  </a>
                {{/each}}
              </div>

              <div class="brp-power-cells">
                {{#each psychic.summaryCells as |cell key|}}
                  <div class="brp-power-cell {{#if cell.rollable}}rollable{{/if}}" {{#if cell.action}}data-action="{{cell.action}}"{{/if}} {{#if cell.tooltipKey}}data-tooltip="{{localize cell.tooltipKey}}"{{/if}}>
                    <span>{{#if cell.labelKey}}{{localize cell.labelKey}}{{else}}{{cell.label}}{{/if}}</span>
                    <strong>{{#if cell.valueKey}}{{localize cell.valueKey}}{{else}}{{cell.value}}{{/if}}</strong>
                  </div>
                {{/each}}
              </div>
            </li>
          {{/each}}
        </ol>
      </section>
    </section>

  {{else}}
    {{! Psychics Development Layout}}
    <ol class="stats-list">
      <div class="skills-tab-grid">
        <div class="skill-cell-name diff-label">{{ localize 'BRP.psyAbility'}}</div>
        <div class="skill-cell diff-label truncate centre">{{ localize 'BRP.base'}}</div>
        <div class="skill-cell diff-label truncate centre" data-tooltip="{{localize 'BRP.personality'}}">{{ localize 'BRP.personalityShort'}}</div>
        <div class="skill-cell diff-label truncate centre" data-tooltip="{{localize 'BRP.profession'}}">{{ localize 'BRP.profShort'}}</div>
        <div class="skill-cell diff-label truncate centre" data-tooltip="{{localize 'BRP.culture'}}">{{ localize 'BRP.culture'}}</div>
        <div class="skill-cell diff-label truncate centre" data-tooltip="{{localize 'BRP.psp'}}">{{ localize 'BRP.personalShort'}}</div>
        <div class="skill-cell diff-label truncate centre" data-tooltip="{{localize 'BRP.experience'}}">{{ localize 'BRP.xp'}}</div>
        <div class="skill-cell diff-label truncate centre" data-tooltip="{{localize 'BRP.effects'}}">{{ localize 'BRP.effectsShort'}}</div>
        <div class="skill-cell diff-label truncate centre" data-tooltip="{{localize 'BRP.category'}}">{{ localize 'BRP.categoryShort'}}</div>
        <div class="skill-cell diff-label truncate centre">{{ localize 'BRP.total'}}</div>
      </div>
      {{#each powersView.psychics.rows as |psychic id|}}
        <li class="item skills-tab-grid" style="list-style:none;" data-item-id="{{psychic.id}}" data-document-class='Item'>
          <div class="skill-cell-name rollable bold" data-action="viewDoc"
            data-tooltip="{{localize 'BRP.viewSpell' type=../powersView.psychics.label }}">{{psychic.title}}</div>
          <input class="skill-cell-input centre inline-edit"
            data-field="base" name="psychic.system.base" type="number"
            value="{{psychic.development.base}}"/>
          <input class="skill-cell-input centre inline-edit {{#if psychic.development.personalityHighlight}} skill-prsnlty {{/if}}"
            data-field="personality" name="psychic.system.personality" type="number"
            value="{{psychic.development.personality}}"/>
          <input class="skill-cell-input centre inline-edit {{#if psychic.development.professionHighlight}} skill-occ {{/if}}"
            data-field="profession" name="psychic.system.profession" type="number"
            value="{{psychic.development.profession}}"/>
          <input class="skill-cell-input centre inline-edit {{#if psychic.development.cultureHighlight}} skill-prsnlty {{/if}}"
            data-field="culture" name="psychic.system.culture" type="number"
            value="{{psychic.development.culture}}"/>
          <input class="skill-cell-input skill-pers centre inline-edit"
            data-field="personal" name="psychic.system.personal" type="number"
            value="{{psychic.development.personal}}"/>
          <input class="skill-cell-input centre inline-edit"
            data-field="xp" name="psychic.system.xp" type="number"
            value="{{psychic.development.xp}}"/>
          <input class="skill-cell-input centre inline-edit"
            data-field="effects" name="psychic.system.effects" type="number"
            value="{{psychic.development.effects}}"/>
          <div class="skill-cell centre">{{psychic.development.categoryBonus}}</div>
          <div class="skill-cell centre lightgrey skill-name rollable" data-action="skillRoll"
            data-tooltip="{{localize 'BRP.skillHint'}}">{{psychic.grandTotal}}</div>
        </li>
      {{/each}}
      <div class="skills-tab-grid">
        <div class="skill-cell-nametotal grey bold">{{ localize 'BRP.total'}}</div>
        <div class="skill-cell centre grey"></div>
        <div class="skill-cell centre grey"></div>
        <div class="skill-cell centre grey">{{this.actor.system.totalProf}}</div>
        <div class="skill-cell centre grey">{{this.actor.system.totalPers}}</div>
        <div class="skill-cell centre grey"></div>
        <div class="skill-cell centre grey"></div>
        <div class="skill-cell centre grey"></div>
        <div class="skill-cell centre grey"></div>
        <div class="skill-cell centre grey"></div>
      </div>
    </ol>
  {{/if}}
</section>
