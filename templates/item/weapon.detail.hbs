<section class="item tab details {{tab.cssClass}}" data-group="primary" data-tab="details">
    <div class="weapon-scores">
      {{#if isGM}}
          <div class="skill-display">{{localize 'BRP.damage'}}</div>
          <div class="stat-input"><input name="system.dmg1" type="text" value="{{item.system.dmg1}}" /></div>
          <div></div>
          <div class="stat-input"><input name="system.dmg2" type="text" value="{{item.system.dmg2}}" /></div>
          <div></div>
          <div class="stat-input"><input name="system.dmg3" type="text" value="{{item.system.dmg3}}" /></div>
          <div class="skill-display">{{localize 'BRP.range'}}</div>
          <div class="stat-input"><input name="system.range1" type="text" value="{{item.system.range1}}" /></div>
          <div></div>
          <div class="stat-input"><input name="system.range2" type="text" value="{{item.system.range2}}" /></div>
          <div></div>
          <div class="stat-input"><input name="system.range3" type="text" value="{{item.system.range3}}" /></div>
        {{else}}
          <div class="skill-display">{{localize 'BRP.damage'}}</div>
          <div class="hitloc-display centre boxed">{{item.system.dmg1}}</div>
          <div></div>
          <div class="hitloc-display centre boxed">{{item.system.dmg2}}</div>
          <div></div>
          <div class="hitloc-display centre boxed">{{item.system.dmg3}}</div>
          <div class="skill-display">{{localize 'BRP.range'}}</div>
          <div class="hitloc-display centre boxed">{{item.system.range1}}</div>
          <div></div>
          <div class="hitloc-display centre boxed">{{item.system.range2}}</div>
          <div></div>
          <div class="hitloc-display centre boxed">{{item.system.range3}}</div>
        {{/if}}
      </div>
      <br>

      {{#if isGM}}
      <div class="weapon-2main-scores">
        <div class="skill-display">{{localize 'BRP.type'}}/{{localize 'BRP.dmgBonusShort'}}</div>
        <div class="stat-input-small">
          <select data-handle-change name="system.weaponType">
            {{selectOptions weaponOptions selected=item.system.weaponType}}
          </select>
        </div>
        <div class="stat-input-small">
          <select data-handle-change name="system.db">
            {{selectOptions damOptions selected=item.system.db}}
          </select>
        </div>
        <div class="skill-display">{{localize 'BRP.skillOpt'}}</div>
        <div class="stat-input-small">
          <select data-handle-change name="system.skill1">
            {{selectOptions wpnSkillOptions1 selected=item.system.skill1}}
          </select>
        </div>
        <div class="stat-input-small">
          <select data-handle-change name="system.skill2">
            {{selectOptions wpnSkillOptions2 selected=item.system.skill2}}
          </select>
        </div>
        <div class="skill-display">{{localize 'BRP.attack'}}/{{localize 'BRP.special'}}</div>
        <div class="weapon-input"><input name="system.att" type="text" value="{{item.system.att}}" /></div>
        <div class="stat-input-small">
          <select data-handle-change name="system.special">
            {{selectOptions specialOptions selected=item.system.special}}
          </select>
        </div>
      </div>
      <div class="weapon-main-scores">
        {{#if item.system.explosive}}
          <div class="skill-display" data-tooltip="{{localize 'BRP.radiusHint'}}">{{localize 'BRP.radius'}}</div>
          <div class="weapon-input"><input name="system.radius" type="text" value="{{item.system.radius}}"
              data-dtype="Number" /></div>
        {{/if}}
        {{#if (eq item.system.weaponType 'artillery')}}
          <div class="skill-display">{{localize 'BRP.crew'}}</div>
          <div class="weapon-input"><input name="system.crew" type="text" value="{{item.system.crew}}" /></div>
        {{else}}
          <div class="skill-display">{{localize 'BRP.hands'}}</div>
          <div class="stat-input-small">
            <select data-handle-change name="system.hands">
              {{selectOptions handedOptions selected=item.system.hands}}
            </select>
          </div>
        {{/if}}
      </div>

      {{#if (eq item.system.weaponType 'artillery')}}
        <div class="weapon-2main-scores">
          <div class="skill-display">{{localize 'BRP.ap'}}/{{item.system.healthLabelAbbr}}</div>
          <div class="weapon-input"><input name="system.ap" type="text" value="{{item.system.ap}}" data-dtype="Number" />
          </div>
          <div class="weapon-input"><input name="system.hp" type="text" value="{{item.system.hp}}" data-dtype="Number" />
          </div>
        </div>
      {{else}}
        <div class="weapon-main-scores">
          {{#if (eq item.system.weaponType 'shield')}}
            <div class="skill-display">{{localize 'BRP.ap'}}</div>
            <div class="weapon-input"><input name="system.ap" type="text" value="{{item.system.ap}}" data-dtype="Number" />
            </div>
          {{else}}
            <div class="skill-display">{{item.system.healthLabelAbbr}}</div>
            <div class="weapon-input"><input name="system.hp" type="text" value="{{item.system.hp}}" data-dtype="Number" />
            </div>
          {{/if}}
        </div>
      {{/if}}

      {{#unless (eq item.system.weaponType 'artillery')}}
        <div class="weapon-2main-scores">
          <div class="skill-display">{{localize 'BRP.StatsStrAbbr'}}/{{localize 'BRP.StatsDexAbbr'}}</div>
          <div class="weapon-input"><input name="system.str" type="text" value="{{item.system.str}}" data-dtype="Number" />
          </div>
          <div class="weapon-input"><input name="system.dex" type="text" value="{{item.system.dex}}" data-dtype="Number" />
          </div>
        </div>
      {{/unless}}

      <div class="brp-weapon-ammo-panel">
        <div class="brp-weapon-ammo-header">
          <span>{{localize 'BRP.weaponAmmoConfig'}}</span>
          <span data-tooltip="{{localize ammoModeHintKey}}">{{ammoModeName}}</span>
        </div>
        <div class="brp-weapon-ammo-grid">
          <label class="brp-weapon-field" data-tooltip="{{localize 'BRP.ammoModeHint'}}">
            <span>{{localize 'BRP.ammoMode'}}</span>
            <select data-handle-change name="system.ammoMode">
              {{selectOptions ammoModeOptions selected=ammoMode}}
            </select>
          </label>
          <label class="brp-weapon-field" data-tooltip="{{localize 'BRP.weaponSortOrderHint'}}">
            <span>{{localize 'BRP.weaponSortOrder'}}</span>
            <input name="system.sortOrder" type="text" value="{{sortOrder}}" data-dtype="Number" />
          </label>
          {{#if isAmmo}}
            <label class="brp-weapon-field">
              <span>{{localize 'BRP.rof'}}</span>
              <input name="system.rof" type="text" value="{{item.system.rof}}" />
            </label>
            <label class="brp-weapon-field" data-tooltip="{{localize 'BRP.ammoCapacityHint'}}">
              <span>{{localize 'BRP.ammoCap'}}</span>
              <input name="system.ammo" type="text" value="{{item.system.ammo}}" data-dtype="Number" />
            </label>
            <label class="brp-weapon-field" data-tooltip="{{localize 'BRP.ammoTypeHint'}}">
              <span>{{localize 'BRP.type'}}</span>
              <input name="system.ammoType" type="text" value="{{item.system.ammoType}}" />
            </label>
          {{/if}}
        </div>
      </div>

      <div class="weapon-main-scores">
        <div class="skill-display">{{localize 'BRP.malfunction'}}</div>
        <div class="weapon-input"><input name="system.mal" type="text" value="{{item.system.mal}}" data-dtype="Number" />
        </div>
        {{#if useWealth}}
          <div class="skill-display">{{localize 'BRP.price'}}</div>
          <div class="stat-input-small">
            <select data-handle-change name="system.price">
              {{selectOptions priceOptions selected=item.system.price}}
            </select>
          </div>
        {{else}}
          <div class="skill-display">{{localize 'BRP.price'}} ({{wealthLabel}})</div>
          <div class="weapon-input"><input name="system.cost" type="text" value="{{item.system.cost}}"
              data-dtype="Number" /></div>
        {{/if}}
        <div class="skill-display">{{localize 'BRP.encSiz'}}</div>
        <div class="weapon-input"><input name="system.enc" type="text" value="{{item.system.enc}}" data-dtype="Number" />
        </div>
        <div class="skill-display">{{localize 'BRP.ppStoreCurr' label=item.system.powerLabelAbbr}}</div>
        <div class="weapon-input"><input name="system.pSCurr" type="text" value="{{item.system.pSCurr}}"
            data-dtype="Number" /></div>
        <div class="skill-display">{{localize 'BRP.ppStoreMax' label=item.system.powerLabelAbbr}}</div>
        <div class="weapon-input"><input name="system.pSMax" type="text" value="{{item.system.pSMax}}"
            data-dtype="Number" /></div>
        {{#if (eq item.system.weaponType 'shield')}}
          <div class="skill-display">{{localize 'BRP.coverage'}}</div>
          <div class="weapon-input"><input name="system.coverage" type="text" value="{{item.system.coverage}}" /></div>
        {{/if}}
      </div>

    {{else}}
      <div class="weapon-2main-scores">
        <div class="skill-display">{{localize 'BRP.type'}}/{{localize 'BRP.dmgBonusShort'}}</div>
        <div class="weapon-display centre boxed">{{weaponCatName}}</div>
        <div class="weapon-display centre boxed">{{damName}}</div>
        <div class="skill-display">{{localize 'BRP.skillOpt'}}</div>
        <div class="weapon-display centre boxed">{{skill1Name}}</div>
        <div class="weapon-display centre boxed">{{skill2Name}}</div>
        <div class="skill-display">{{localize 'BRP.attack'}}/{{localize 'BRP.special'}}</div>
        <div class="weapon-display centre boxed">{{item.system.att}}</div>
        <div class="weapon-display centre boxed">{{specName}}</div>
      </div>
      <div class="weapon-main-scores">
        {{#if item.system.explosive}}
          <div class="skill-display" data-tooltip="{{localize 'BRP.radiusHint'}}">{{localize 'BRP.radius'}}</div>
          <div class="weapon-display centre boxed">{{item.system.radius}}</div>
        {{/if}}
        {{#if (eq item.system.weaponType 'artillery')}}
          <div class="skill-display">{{localize 'BRP.crew'}}</div>
          <div class="weapon-display centre boxed">{{item.system.crew}}</div>
        {{else}}
          <div class="skill-display">{{localize 'BRP.hands'}}</div>
          <div class="weapon-display centre boxed">{{handedName}}</div>
        {{/if}}
      </div>

      {{#if (eq item.system.weaponType 'artillery')}}
        <div class="weapon-2main-scores">
          <div class="skill-display">{{localize 'BRP.ap'}}/{{item.system.healthLabelAbbr}}</div>
          <div class="weapon-display centre boxed">{{item.system.ap}}</div>
          <div class="weapon-display centre boxed">{{item.system.hp}}</div>
        </div>
      {{else}}
        <div class="weapon-main-scores">
          {{#if (eq item.system.weaponType 'shield')}}
            <div class="skill-display">{{localize 'BRP.ap'}}</div>
            <div class="weapon-display centre boxed">{{item.system.ap}}</div>
          {{else}}
            <div class="skill-display">{{item.system.healthLabelAbbr}}</div>
            <div class="weapon-display centre boxed">{{item.system.hp}}</div>
          {{/if}}
        </div>
      {{/if}}

      {{#unless (eq item.system.weaponType 'artillery')}}
        <div class="weapon-2main-scores">
          <div class="skill-display">{{localize 'BRP.StatsStrAbbr'}}/{{localize 'BRP.StatsDexAbbr'}}</div>
          <div class="weapon-display centre boxed">{{item.system.str}}</div>
          <div class="weapon-display centre boxed">{{item.system.dex}}</div>
        </div>
      {{/unless}}

      <div class="brp-weapon-ammo-panel">
        <div class="brp-weapon-ammo-header">
          <span>{{localize 'BRP.weaponAmmoConfig'}}</span>
          <span data-tooltip="{{localize ammoModeHintKey}}">{{ammoModeName}}</span>
        </div>
        <div class="brp-weapon-ammo-grid">
          <div class="brp-weapon-field" data-tooltip="{{localize ammoModeHintKey}}">
            <span>{{localize 'BRP.ammoMode'}}</span>
            <div class="weapon-display centre boxed">{{ammoModeName}}</div>
          </div>
          <div class="brp-weapon-field" data-tooltip="{{localize 'BRP.weaponSortOrderHint'}}">
            <span>{{localize 'BRP.weaponSortOrder'}}</span>
            <div class="weapon-display centre boxed">{{sortOrder}}</div>
          </div>
          {{#if isAmmo}}
            <div class="brp-weapon-field">
              <span>{{localize 'BRP.rof'}}</span>
              <div class="weapon-display centre boxed">{{item.system.rof}}</div>
            </div>
            <div class="brp-weapon-field" data-tooltip="{{localize 'BRP.ammoCapacityHint'}}">
              <span>{{localize 'BRP.ammoCap'}}</span>
              <div class="weapon-display centre boxed">{{item.system.ammo}}</div>
            </div>
            <div class="brp-weapon-field" data-tooltip="{{localize 'BRP.ammoTypeHint'}}">
              <span>{{localize 'BRP.type'}}</span>
              <div class="weapon-display centre boxed">{{item.system.ammoType}}</div>
            </div>
          {{/if}}
        </div>
      </div>

      <div class="weapon-main-scores">
        <div class="skill-display">{{localize 'BRP.malfunction'}}</div>
        <div class="weapon-display centre boxed">{{item.system.mal}}</div>
        {{#if useWealth}}
          <div class="skill-display">{{localize 'BRP.price'}}</div>
          <div class="weapon-display centre boxed">{{priceName}}</div>
        {{else}}
          <div class="skill-display">{{localize 'BRP.price'}} ({{wealthLabel}})</div>
          <div class="weapon-display centre boxed">{{item.system.cost}}</div>
        {{/if}}
        <div class="skill-display">{{localize 'BRP.enc'}}</div>
        <div class="weapon-display centre boxed">{{item.system.enc}}</div>
        <div class="skill-display">{{localize 'BRP.ppStoreCurr' label=item.system.powerLabelAbbr}}</div>
        <div class="weapon-input"><input name="system.pSCurr" type="text" value="{{item.system.pSCurr}}"
            data-dtype="Number" /></div>
        <div class="skill-display">{{localize 'BRP.ppStoreMax' label=item.system.powerLabelAbbr}}</div>
        <div class="weapon-input"><input name="system.pSMax" type="text" value="{{item.system.pSMax}}"
            data-dtype="Number" /></div>
        {{#if (eq item.system.weaponType 'shield')}}
          <div class="skill-display">{{localize 'BRP.coverage'}}</div>
          <div class="weapon-display centre boxed">{{item.system.coverage}}</div>
        {{/if}}

      </div>
    {{/if}}

    <br>

    <div class="item-title"> {{localize 'BRP.options'}}:</div>
    <div class="base-5grid">
      <div class="skill-cat {{#if item.system.parry}} toggle-active  {{/if}}"
        data-tooltip="{{localize 'BRP.parryHint'}}" data-action="itemToggle" data-property="parry">{{localize 'BRP.parry'}}</div>
      <div class="skill-cat {{#if item.system.acid}} toggle-active  {{/if}}"
        data-action="itemToggle" data-property="acid">{{localize 'BRP.acid'}}</div>
      <div class="skill-cat {{#if item.system.burst}} toggle-active  {{/if}}"
        data-action="itemToggle" data-property="burst">{{localize 'BRP.burst'}}</div>
      <div class="skill-cat {{#if item.system.choke}} toggle-active  {{/if}}"
        data-action="itemToggle" data-property="choke">{{localize 'BRP.choke'}}</div>
      <div class="skill-cat {{#if item.system.cold}} toggle-active  {{/if}}"
        data-action="itemToggle" data-property="cold">{{localize 'BRP.cold'}}</div>
      <div class="skill-cat {{#if item.system.constrict}} toggle-active  {{/if}}"
        data-action="itemToggle" data-property="constrict">{{localize 'BRP.constrict'}}</div>
      <div class="skill-cat {{#if item.system.disease}} toggle-active  {{/if}}"
        data-action="itemToggle" data-property="disease">{{localize 'BRP.disease'}}</div>
      <div class="skill-cat {{#if item.system.emp}} toggle-active  {{/if}}"
        data-action="itemToggle" data-property="emp">{{localize 'BRP.emp'}}</div>
      <div class="skill-cat {{#if item.system.entangle}} toggle-active  {{/if}}"
        data-action="itemToggle" data-property="entangle">{{localize 'BRP.entangle'}}</div>
      <div class="skill-cat {{#if item.system.explosive}} toggle-active  {{/if}}"
        data-action="itemToggle" data-property="explosive">{{localize 'BRP.explosive'}}</div>
      <div class="skill-cat {{#if item.system.fire}} toggle-active  {{/if}}"
        data-action="itemToggle" data-property="fire">{{localize 'BRP.fire'}}</div>
      <div class="skill-cat {{#if item.system.pierce}} toggle-active  {{/if}}"
        data-action="itemToggle" data-property="pierce">{{localize 'BRP.pierce'}}</div>
      <div class="skill-cat {{#if item.system.poison}} toggle-active  {{/if}}"
        data-action="itemToggle" data-property="poison">{{localize 'BRP.poison'}}</div>
      <div class="skill-cat {{#if item.system.sonic}} toggle-active  {{/if}}"
        data-action="itemToggle" data-property="sonic">{{localize 'BRP.sonic'}}</div>
      <div class="skill-cat {{#if item.system.stun}} toggle-active  {{/if}}"
        data-action="itemToggle" data-property="stun">{{localize 'BRP.stun'}}</div>
      <div class="skill-cat {{#if item.system.spclDmg}} toggle-active  {{/if}}"
        data-action="itemToggle" data-property="spclDmg">{{localize 'BRP.special'}}</div>
    </div>
    <br>

    <div class="item-title">{{localize 'BRP.inventoryFields'}}:</div>
    <div class="weapon-main-scores">
      <div class="skill-display" data-tooltip="{{localize 'BRP.containerIdHint'}}">{{localize 'BRP.containerId'}}</div>
      <div class="weapon-input"><input name="system.containerId" type="text" value="{{item.system.containerId}}" /></div>
    </div>
    <div class="item-title">{{localize 'BRP.bonuses'}}:</div>
    <div class="brp-item-bonus-editor">
      <input type="hidden" name="system.bonusesEditor" value="1" />
      <div class="brp-item-bonus-editor-head">
        <span>{{localize 'BRP.inventoryBonusEditorHint'}}</span>
        <button type="button" class="brp-item-bonus-add" data-action="inventoryBonusAdd" data-tooltip="{{localize 'BRP.inventoryBonusAdd'}}">
          <i class="fas fa-plus"></i>
        </button>
      </div>
      <div class="brp-item-bonus-list">
        {{#each bonusEditorRows as |bonus|}}
          <div class="brp-item-bonus-row brp-item-bonus-row-{{bonus.mode}}">
            <label class="brp-item-bonus-field">
              <span>{{localize 'BRP.inventoryBonusMode'}}</span>
              <select name="system.bonusesEditor.{{bonus.index}}.mode">
                {{selectOptions ../bonusModeOptions selected=bonus.mode}}
              </select>
            </label>
            <label class="brp-item-bonus-field">
              <span>{{localize 'BRP.inventoryBonusTarget'}}</span>
              <input name="system.bonusesEditor.{{bonus.index}}.skill" type="text" value="{{bonus.skill}}" />
            </label>
            <label class="brp-item-bonus-field">
              <span>{{localize 'BRP.inventoryBonusValue'}}</span>
              <input name="system.bonusesEditor.{{bonus.index}}.value" type="text" value="{{bonus.value}}" />
            </label>
            <label class="brp-item-bonus-field">
              <span>{{localize 'BRP.difficulty'}}</span>
              <select name="system.bonusesEditor.{{bonus.index}}.difficulty">
                {{selectOptions ../bonusDifficultyOptions selected=bonus.difficulty}}
              </select>
            </label>
            <label class="brp-item-bonus-field">
              <span>{{localize 'BRP.inventoryBonusNote'}}</span>
              <input name="system.bonusesEditor.{{bonus.index}}.text" type="text" value="{{bonus.text}}" />
            </label>
            <label class="brp-item-bonus-check" data-tooltip="{{localize 'BRP.inventoryBonusRequiresCarried'}}">
              <input name="system.bonusesEditor.{{bonus.index}}.requiresCarried" type="checkbox" {{checked bonus.requiresCarried}} />
              <span>{{localize 'BRP.carried'}}</span>
            </label>
            <button type="button" class="brp-item-bonus-delete" data-action="inventoryBonusDelete" data-bonus-index="{{bonus.index}}" data-tooltip="{{localize 'BRP.delete'}}">
              <i class="fas fa-trash"></i>
            </button>
          </div>
        {{else}}
          <div class="brp-item-bonus-empty">{{localize 'BRP.none'}}</div>
        {{/each}}
      </div>
    </div>
    <br>

    {{#if hasOwner}}
      <div class="weapon-2main-scores">
        <div class="skill-display" data-tooltip="{{ localize 'BRP.actualENCHint'}}">{{localize 'BRP.actualENC'}}/{{localize
          'BRP.status'}}</div>
        <div class="gear-display-plain tertiary">{{item.system.actlEnc}}</div>
        <div class="stat-input-small">
          <select data-handle-change name="system.equipStatus">
            {{selectOptions equippedOptions selected=item.system.equipStatus}}
          </select>
        </div>
        <div class="skill-display">{{localize 'BRP.hpCurr' label=item.system.healthLabelAbbr}}</div>
        <div class="weapon-input"><input name="system.hpCurr" type="text" value="{{item.system.hpCurr}}"
            data-dtype="Number" /></div>
        <div></div>
        {{#if npcOwner}}
          <div class="skill-display new-row">{{localize 'BRP.base'}}%</div>
          <div class="weapon-input"><input name="system.npcVal" type="text" value="{{item.system.npcVal}}"
              data-dtype="Number" /></div>
          <div></div>
        {{/if}}
      </div>
      <div class="brp-weapon-ammo-panel brp-weapon-ammo-state">
        <div class="brp-weapon-ammo-header">
          <span>{{localize 'BRP.weaponAmmoState'}}</span>
          <span data-tooltip="{{localize ammoModeHintKey}}">{{ammoModeName}}</span>
        </div>
        <div class="brp-weapon-ammo-grid">
          <label class="brp-weapon-field" data-tooltip="{{localize 'BRP.ammoCurrentHint'}}">
            <span>{{localize 'BRP.ammoCurr'}}</span>
            <input name="system.ammoCurr" type="text" value="{{item.system.ammoCurr}}" data-dtype="Number" />
          </label>
          <label class="brp-weapon-field" data-tooltip="{{localize ammoQuantityHintKey}}">
            <span>{{localize 'BRP.quantity'}}</span>
            <input name="system.quantity" type="text" value="{{item.system.quantity}}" data-dtype="Number" />
          </label>
          <label class="brp-weapon-field" data-tooltip="{{localize 'BRP.magazineCountHint'}}">
            <span>{{localize 'BRP.magazineCount'}}</span>
            <input name="system.magazineCount" type="text" value="{{magazineCount}}" data-dtype="Number" />
          </label>
        </div>
      </div>
    {{/if}}
</section>
